# Example environment variables (DO NOT put real secrets here)

# Anthropic key for the grounded AI chat (server-side, optional).
# When set, /api/ai/chat answers via Claude tool-use over the dataset.
# When empty, the chat falls back to the local keyword engine.
ANTHROPIC_API_KEY=

# Model used by the AI chat (J-Lab standard: Claude Haiku 4.5).
ANTHROPIC_MODEL=claude-haiku-4-5

# Max tool-call turns per AI chat request before degrading to local engine.
AI_MAX_TOOL_TURNS=6
